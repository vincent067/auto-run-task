# ─────────────────────────────────────────────────────────────────
# AI Agent LLM 配置（复制为 .env 后填入实际密钥，切勿提交 git）
# ─────────────────────────────────────────────────────────────────

# ── MiniMax Coding Plan（Anthropic Messages API 兼容）──
# 文档: https://platform.minimaxi.com/docs/coding-plan/quickstart
MINIMAX_API_KEY=sk-cp-your-key-here
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
MINIMAX_MODEL=MiniMax-M2.7

# ── Kimi Coding（Anthropic Messages API 兼容）──
# 文档: https://platform.moonshot.cn/docs/introduction
KIMI_API_KEY=sk-kimi-your-key-here
KIMI_BASE_URL=https://api.kimi.com/coding/
KIMI_MODEL=kimi-for-coding

# ── Agent 默认行为配置 ──
AGENT_DEFAULT_PROVIDER=minimax    # minimax | kimi
AGENT_MAX_TOKENS=4000
AGENT_TEMPERATURE=0.2

# ── Doubao 多模态 Embedding（可选，未来扩展用）──
# DOUBAO_API_KEY=your-doubao-key
# DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
